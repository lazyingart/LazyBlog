WP_SITE_URL=https://example.com
WP_USERNAME=
# WordPress Application Password. Quote it in .env if it contains spaces.
WP_APP_PASSWORD=
WP_POST_STATUS=publish
WP_EXPORT_DIR=out/posts
LAZYBLOG_CONTENT_DIR=content/posts

LAZYBLOG_WEBAPP_HOST=127.0.0.1
LAZYBLOG_WEBAPP_PORT=8765
LAZYBLOG_WEBAPP_MODEL=gpt-5.4
LAZYBLOG_WEBAPP_REASONING=low
LAZYBLOG_WEBAPP_CODEX_TIMEOUT=1800
LAZYBLOG_WEBAPP_COMMIT_PUSH=false
LAZYBLOG_API_TOKEN=

# WordPress plugin provider override: lazyblog, openai, or deepseek.
LAZYBLOG_TRANSLATION_PROVIDER=lazyblog
OPENAI_API_KEY=
LAZYBLOG_OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=
LAZYBLOG_DEEPSEEK_MODEL=deepseek-v4-flash
