{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["language", "markdown", "notes"],
  "properties": {
    "language": {
      "type": "string",
      "enum": ["en", "ja", "zh"]
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
