{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reply",
    "intent",
    "summary",
    "should_draft",
    "suggested_title",
    "next_actions",
    "memory_tags",
    "confidence"
  ],
  "properties": {
    "reply": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": ["capture", "draft", "publish", "research", "maintenance", "chat", "unclear"]
    },
    "summary": {
      "type": "string"
    },
    "should_draft": {
      "type": "boolean"
    },
    "suggested_title": {
      "type": "string"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
