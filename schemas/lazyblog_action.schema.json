{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "post_reference",
    "category",
    "parent_category",
    "sync_mode",
    "reason",
    "confidence"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["select_post", "create_category", "sync_categories", "no_op"]
    },
    "post_reference": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "parent_category": {
      "type": "string"
    },
    "sync_mode": {
      "type": "string",
      "enum": ["pull", "push", "auto", ""]
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
